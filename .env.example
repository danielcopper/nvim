# Copy this file to .env and fill in your values
# All variables are optional — plugins fall back to local mode without them

# SonarQube Cloud (formerly SonarCloud)
# Token: https://sonarcloud.io/account/security
# Org key: your GitHub username or organization name
SONARCLOUD_ORG=your-github-username
SONAR_TOKEN=sqp_xxxxxxxxxxxxxxxxxxxx

# SonarQube Server (self-hosted) — only if you have one
# SONARQUBE_URL=https://sonarqube.yourcompany.com

# Azure DevOps PAT (for adopure.nvim)
# AZURE_DEVOPS_EXT_PAT=your_pat_here
